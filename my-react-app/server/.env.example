# Environment variables for Railway deployment
# Copy this to .env and fill in your actual values

# Railway automatically sets PORT, but you can override for local dev
# PORT=3001

# RTSP stream URLs (keep these private!)
RTSP_ENTRANCE_URL=rtsp://your-entrance-stream-url
RTSP_EXIT_URL=rtsp://your-exit-stream-url

# Railway deployment URL (automatically set by Railway)
# RAILWAY_STATIC_URL=https://your-app-name.railway.app

# Node environment
NODE_ENV=production